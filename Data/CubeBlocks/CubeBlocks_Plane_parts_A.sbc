<!--
Update 09-08-2020 increase health for wing parts 2x for Large, 5x for small
Large:
<GeneralDamageMultiplier>0.5</GeneralDamageMultiplier>
Small:
<GeneralDamageMultiplier>0.2</GeneralDamageMultiplier>


-->

<!-- aero-wing_1x5x1_rounded_edge SMALL -->
    <Definition>
      <Id>
        <TypeId>TerminalBlock</TypeId>
        <SubtypeId>aero-wing_1x5x1_rounded_edge_Small</SubtypeId>
      </Id>
      <DisplayName>DisplayName_Wing_1x5x1_rounded_edge</DisplayName>
      <Icon>Textures\Icons\aero-wing_1x5x1_rounded_edge.dds</Icon>
      <CubeSize>Small</CubeSize>
	  <GeneralDamageMultiplier>0.2</GeneralDamageMultiplier>
      <BlockTopology>TriangleMesh</BlockTopology>
      <Components>
	<Component Subtype="SteelPlate" Count="2" />
        <Component Subtype="SteelPlate" Count="2" />
        <Component Subtype="MetalGrid" Count="1" />
      </Components>
      <CriticalComponent Subtype="SteelPlate" Index="0" />

	<Size x="1" y="1" z="5" />
	<ModelOffset x="0" y="0" z="0" />
	<Model>Models\aero-wing_1x5x1_rounded_edge\aero-wing_1x5x1_rounded_edge_Small.mwm</Model>
	<BuildProgressModels>
				<Model BuildPercentUpperBound="1.00" File="Models\aero-wing_1x5x1_rounded_edge\aero-wing_1x5x1_rounded_edge_Small_Constr1.mwm" />
	</BuildProgressModels>
	<MountPoints>
		<MountPoint Side="Front" StartX="0.00" StartY="0.00" EndX="1.00" EndY="1.00" />
		<MountPoint Side="Back" StartX="0.00" StartY="0.00" EndX="1.00" EndY="1.00" />
		<MountPoint Side="Right" StartX="0.00" StartY="0.00" EndX="5.00" EndY="1.00" Default="true"/>
	</MountPoints>
        <!-- right default -->
	<BlockPairName>aero-wing_1x5x1_rounded_edge</BlockPairName>
	<MirroringX>Z</MirroringX>
	<MirroringY>None</MirroringY>
	<MirroringZ>X</MirroringZ>
      <EdgeType>Light</EdgeType>
      <BuildTimeSeconds>5</BuildTimeSeconds>
      <PCU>10</PCU>
    </Definition>

