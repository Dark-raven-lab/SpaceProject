                <Block Type="CubeBlock" Subtype="Plane_SmallHalfArmorBlock" />
                <Block Type="CubeBlock" Subtype="Plane_SmallHalfSlopeArmorBlock" />
            </Blocks>
        </BlockVariantGroup>
	
	
	    <BlockVariantGroup>
