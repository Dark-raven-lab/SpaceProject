                <Block Type="CubeBlock" Subtype="Plane_LargeHalfSlopeArmorBlock" />
                <Block Type="CubeBlock" Subtype="Plane_SmallBlockArmorBlock" />
                <Block Type="CubeBlock" Subtype="Plane_SmallBlockArmorSlope" />
				<Block Type="CubeBlock" Subtype="Plane_SmallBlockArmorCorner" />
